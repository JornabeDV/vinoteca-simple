generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  EMPLOYEE
  ADMIN
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum ProductType {
  WINE
  BEER
  SPIRIT
  WATER
  OTHER
}

enum MovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  CORRECTION
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  DIGITAL_WALLET
  ACCOUNT
}

model Business {
  id         String         @id @default(uuid())
  name       String
  inviteCode String         @unique @map("invite_code")
  status     BusinessStatus @default(ACTIVE)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  users      User[]
  products   Product[]
  categories Category[]
  customers  Customer[]
  payments   Payment[]
  sales      Sale[]
  promotions Promotion[]
  inventoryMovements InventoryMovement[]

  @@map("businesses")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String
  role          UserRole  @default(EMPLOYEE)
  image         String?
  businessId    String?   @map("business_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  business      Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales         Sale[]
  inventoryMovements InventoryMovement[]

  @@index([businessId])
  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  businessId  String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("categories")
}

model Product {
  id            String        @id @default(uuid())
  name          String
  brand         String
  style         String
  year          Int?
  description   String?
  productType   ProductType   @default(WINE) @map("product_type")
  costPrice     Decimal       @map("cost_price") @db.Decimal(10, 2)
  salePrice     Decimal       @map("sale_price") @db.Decimal(10, 2)
  currentStock  Int           @default(0) @map("current_stock")
  minStock      Int           @default(0) @map("min_stock")
  image         String?
  status        ProductStatus @default(ACTIVE)
  categoryId    String?       @map("category_id")
  businessId    String        @map("business_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems     SaleItem[]
  promotionItems PromotionItem[]
  salePromotionItems SalePromotionItem[]
  inventoryMovements InventoryMovement[]

  @@index([status])
  @@index([name])
  @@index([brand])
  @@index([productType])
  @@index([categoryId])
  @@index([businessId])
  @@map("products")
}

model InventoryMovement {
  id            String       @id @default(uuid())
  productId     String       @map("product_id")
  userId        String       @map("user_id")
  businessId    String       @map("business_id")
  quantity      Int
  type          MovementType
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")

  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([businessId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String?
  dni         String?
  address     String?
  notes       String?
  businessId  String    @map("business_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales       Sale[]
  payments    Payment[]

  @@index([businessId])
  @@index([name])
  @@map("customers")
}

model Payment {
  id          String    @id @default(uuid())
  amount      Decimal   @db.Decimal(10, 2)
  notes       String?
  customerId  String    @map("customer_id")
  businessId  String    @map("business_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([businessId])
  @@index([createdAt])
  @@map("payments")
}

model Sale {
  id            String      @id @default(uuid())
  saleNumber    String      @unique @map("sale_number")
  userId        String      @map("user_id")
  businessId    String      @map("business_id")
  customerId    String?     @map("customer_id")
  totalAmount   Decimal     @map("total_amount") @db.Decimal(10, 2)
  isPaid        Boolean     @default(true) @map("is_paid")
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  createdAt     DateTime    @default(now()) @map("created_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         SaleItem[]
  salePromotions SalePromotion[]

  @@index([userId])
  @@index([businessId])
  @@index([customerId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id            String      @id @default(uuid())
  saleId        String      @map("sale_id")
  productId     String      @map("product_id")
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(10, 2)
  totalPrice    Decimal     @map("total_price") @db.Decimal(10, 2)

  sale          Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Promotion {
  id            String        @id @default(uuid())
  name          String
  description   String?
  salePrice     Decimal       @map("sale_price") @db.Decimal(10, 2)
  status        ProductStatus @default(ACTIVE)
  businessId    String        @map("business_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items         PromotionItem[]
  sales         SalePromotion[]

  @@index([status])
  @@index([businessId])
  @@map("promotions")
}

model PromotionItem {
  id            String    @id @default(uuid())
  promotionId   String    @map("promotion_id")
  productId     String    @map("product_id")
  quantity      Int

  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([productId])
  @@map("promotion_items")
}

model SalePromotion {
  id            String    @id @default(uuid())
  saleId        String    @map("sale_id")
  promotionId   String    @map("promotion_id")
  name          String
  salePrice     Decimal   @map("sale_price") @db.Decimal(10, 2)
  quantity      Int
  totalPrice    Decimal   @map("total_price") @db.Decimal(10, 2)

  sale          Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  items         SalePromotionItem[]

  @@index([saleId])
  @@index([promotionId])
  @@map("sale_promotions")
}

model SalePromotionItem {
  id              String        @id @default(uuid())
  salePromotionId String        @map("sale_promotion_id")
  productId       String        @map("product_id")
  quantity        Int

  salePromotion   SalePromotion @relation(fields: [salePromotionId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([salePromotionId])
  @@index([productId])
  @@map("sale_promotion_items")
}
