generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  EMPLOYEE
  ADMIN
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum ProductType {
  WINE
  BEER
  SPIRIT
  WATER
  NON_ALCOHOLIC
  OTHER
}

enum MovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  CORRECTION
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  DIGITAL_WALLET
  ACCOUNT
}

enum SupplierDebtStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model Business {
  id         String         @id @default(uuid())
  name       String
  logo       String?
  inviteCode String         @unique @map("invite_code")
  status     BusinessStatus @default(ACTIVE)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  users      User[]
  products   Product[]
  categories Category[]
  customers  Customer[]
  payments   Payment[]
  sales      Sale[]
  promotions Promotion[]
  purchases  Purchase[]
  suppliers  Supplier[]
  supplierDebts SupplierDebt[]
  supplierPayments SupplierPayment[]
  inventoryMovements InventoryMovement[]
  expenseCategories ExpenseCategory[]
  expenses   Expense[]

  @@map("businesses")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String
  role          UserRole  @default(EMPLOYEE)
  image         String?
  businessId    String?   @map("business_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  business      Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales         Sale[]
  inventoryMovements InventoryMovement[]

  @@index([businessId])
  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  businessId  String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("categories")
}

model Product {
  id            String        @id @default(uuid())
  name          String
  brand         String
  style         String
  year          Int?
  description   String?
  productType   ProductType   @default(WINE) @map("product_type")
  costPrice     Decimal       @map("cost_price") @db.Decimal(10, 2)
  salePrice     Decimal       @map("sale_price") @db.Decimal(10, 2)
  currentStock  Int           @default(0) @map("current_stock")
  minStock      Int           @default(0) @map("min_stock")
  image         String?
  status        ProductStatus @default(ACTIVE)
  categoryId    String?       @map("category_id")
  businessId    String        @map("business_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  promotionItems PromotionItem[]
  salePromotionItems SalePromotionItem[]
  inventoryMovements InventoryMovement[]

  @@index([status])
  @@index([name])
  @@index([brand])
  @@index([productType])
  @@index([categoryId])
  @@index([businessId])
  @@map("products")
}

model InventoryMovement {
  id            String       @id @default(uuid())
  productId     String       @map("product_id")
  userId        String       @map("user_id")
  businessId    String       @map("business_id")
  purchaseId    String?      @map("purchase_id")
  quantity      Int
  type          MovementType
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")

  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchase      Purchase?    @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@index([businessId])
  @@index([purchaseId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String
  color       String?
  businessId  String    @map("business_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("expense_categories")
}

model Expense {
  id            String    @id @default(uuid())
  concept       String
  amount        Decimal   @db.Decimal(10, 2)
  date          DateTime  @default(now()) @db.Date
  notes         String?
  categoryId    String?   @map("category_id")
  businessId    String    @map("business_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([date])
  @@index([categoryId])
  @@map("expenses")
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String?
  dni         String?
  address     String?
  notes       String?
  businessId  String    @map("business_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales       Sale[]
  payments    Payment[]

  @@index([businessId])
  @@index([name])
  @@map("customers")
}

model Payment {
  id          String    @id @default(uuid())
  amount      Decimal   @db.Decimal(10, 2)
  notes       String?
  customerId  String    @map("customer_id")
  businessId  String    @map("business_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([businessId])
  @@index([createdAt])
  @@map("payments")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  contactName String?  @map("contact_name")
  phone       String?
  email       String?
  cbuAlias    String?  @map("cbu_alias")
  notes       String?
  businessId  String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  debts    SupplierDebt[]
  payments SupplierPayment[]
  purchases Purchase[]

  @@index([businessId])
  @@map("suppliers")
}

model SupplierDebt {
  id            String             @id @default(uuid())
  supplierId    String             @map("supplier_id")
  businessId    String             @map("business_id")
  purchaseId    String?            @map("purchase_id")
  invoiceNumber String?            @map("invoice_number")
  concept       String
  totalAmount   Decimal            @map("total_amount") @db.Decimal(10, 2)
  paidAmount    Decimal            @default(0) @map("paid_amount") @db.Decimal(10, 2)
  issueDate     DateTime           @default(now()) @map("issue_date")
  dueDate       DateTime?          @map("due_date")
  status        SupplierDebtStatus @default(PENDING)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  supplier Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchase Purchase?       @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  payments SupplierPayment[]

  @@index([supplierId])
  @@index([businessId])
  @@index([purchaseId])
  @@index([status])
  @@index([dueDate])
  @@map("supplier_debts")
}

model SupplierPayment {
  id            String    @id @default(uuid())
  supplierId    String    @map("supplier_id")
  debtId        String?   @map("debt_id")
  purchaseId    String?   @map("purchase_id")
  businessId    String    @map("business_id")
  amount        Decimal   @db.Decimal(10, 2)
  paymentDate   DateTime  @default(now()) @map("payment_date")
  paymentMethod String?   @map("payment_method")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  supplier Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  debt     SupplierDebt?  @relation(fields: [debtId], references: [id], onDelete: SetNull)
  purchase Purchase?      @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([debtId])
  @@index([purchaseId])
  @@index([businessId])
  @@index([paymentDate])
  @@map("supplier_payments")
}

model Purchase {
  id            String    @id @default(uuid())
  supplierId    String    @map("supplier_id")
  businessId    String    @map("business_id")
  invoiceNumber String?   @map("invoice_number")
  totalAmount   Decimal   @map("total_amount") @db.Decimal(10, 2)
  purchaseDate  DateTime  @default(now()) @map("purchase_date")
  isPaid        Boolean   @default(false) @map("is_paid")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  supplier Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    PurchaseItem[]
  debts    SupplierDebt[]
  payments SupplierPayment[]
  inventoryMovements InventoryMovement[]

  @@index([supplierId])
  @@index([businessId])
  @@index([purchaseDate])
  @@map("purchases")
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchaseId    String   @map("purchase_id")
  productId     String   @map("product_id")
  quantity      Int
  unitCost      Decimal  @map("unit_cost") @db.Decimal(10, 2)
  totalCost     Decimal  @map("total_cost") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model Sale {
  id                 String        @id @default(uuid())
  saleNumber         String        @unique @map("sale_number")
  userId             String        @map("user_id")
  businessId         String        @map("business_id")
  customerId         String?       @map("customer_id")
  totalAmount        Decimal       @map("total_amount") @db.Decimal(10, 2)
  discountPercentage Int           @default(0) @map("discount_percentage")
  discountAmount     Decimal       @default(0) @db.Decimal(10, 2) @map("discount_amount")
  isPaid             Boolean       @default(true) @map("is_paid")
  paymentMethod      PaymentMethod @default(CASH) @map("payment_method")
  createdAt          DateTime      @default(now()) @map("created_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         SaleItem[]
  salePromotions SalePromotion[]

  @@index([userId])
  @@index([businessId])
  @@index([customerId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id            String      @id @default(uuid())
  saleId        String      @map("sale_id")
  productId     String      @map("product_id")
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(10, 2)
  totalPrice    Decimal     @map("total_price") @db.Decimal(10, 2)

  sale          Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Promotion {
  id            String        @id @default(uuid())
  name          String
  description   String?
  salePrice     Decimal       @map("sale_price") @db.Decimal(10, 2)
  status        ProductStatus @default(ACTIVE)
  businessId    String        @map("business_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items         PromotionItem[]
  sales         SalePromotion[]

  @@index([status])
  @@index([businessId])
  @@map("promotions")
}

model PromotionItem {
  id            String    @id @default(uuid())
  promotionId   String    @map("promotion_id")
  productId     String    @map("product_id")
  quantity      Int

  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([productId])
  @@map("promotion_items")
}

model SalePromotion {
  id            String    @id @default(uuid())
  saleId        String    @map("sale_id")
  promotionId   String    @map("promotion_id")
  name          String
  salePrice     Decimal   @map("sale_price") @db.Decimal(10, 2)
  quantity      Int
  totalPrice    Decimal   @map("total_price") @db.Decimal(10, 2)

  sale          Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  items         SalePromotionItem[]

  @@index([saleId])
  @@index([promotionId])
  @@map("sale_promotions")
}

model SalePromotionItem {
  id              String        @id @default(uuid())
  salePromotionId String        @map("sale_promotion_id")
  productId       String        @map("product_id")
  quantity        Int

  salePromotion   SalePromotion @relation(fields: [salePromotionId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([salePromotionId])
  @@index([productId])
  @@map("sale_promotion_items")
}
